# --- Supabase (AIQ project) ---
# Server-only — read at runtime on Vercel via process.env inside handlers.
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<legacy-anon-jwt-or-sb_publishable_*>"
# Optional: server-only service role key for admin operations (bypasses RLS).
# Only set if you actually use src/integrations/supabase/client.server.ts.
# SUPABASE_SERVICE_ROLE_KEY=""

# Public — inlined into the client bundle at build time via VITE_* prefix.
VITE_SUPABASE_URL="https://<project>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<legacy-anon-jwt-or-sb_publishable_*>"
VITE_SUPABASE_PROJECT_ID="<project>"

# --- OpenAI ---
# Required by /api/analyze-food (vision macro estimation) and /api/coach
# (nutrition chat). Server-only — read at runtime inside the handler.
# Without this, both routes return HTTP 500 "Missing OPENAI_API_KEY".
OPENAI_API_KEY=""
